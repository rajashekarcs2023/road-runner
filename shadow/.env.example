# ===== Required from day one =====
# Internal integration token from notion.so/profile/integrations
# Capabilities required: Read content, Update content, Insert content
NOTION_API_TOKEN=ntn_xxx

# Anthropic API key from console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-xxx

# ===== Required for setup-db (one-time) =====
# A Notion page in your workspace where the Customer Requests DB will be created.
# Create an empty page, connect your integration via the three-dot menu -> Connections.
NOTION_PARENT_PAGE_ID=

# ===== Populated after setup-db + first deploy =====
# Printed by `bun run setup-db`
REQUESTS_DB_ID=

# Printed by `ntn workers deploy` (the shadow DB is created automatically by worker.sync)
REQUESTS_SHADOW_DB_ID=

# Pre-created blank pages titled "Diff Report" and "Audit Log", integration connected.
# Used by the diff renderer and the audit log writer respectively.
DIFF_REPORT_PAGE_ID=
AUDIT_LOG_PAGE_ID=
